<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
* { margin: 0; padding: 0; }
body { background: transparent; }
</style>
</head>
<body>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 484 80" width="1936" height="320">
  <!-- Connecting line -->
  <polyline points="30,41 118,32 206,19 294,24 382,30 470,27" fill="none" stroke="#DCDCDE" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
  <!-- Past dots: grey rings -->
  <circle cx="30" cy="41" r="3.5" fill="white" stroke="#AEAEB2" stroke-width="1.5"/>
  <circle cx="118" cy="32" r="3.5" fill="white" stroke="#AEAEB2" stroke-width="1.5"/>
  <circle cx="206" cy="19" r="3.5" fill="white" stroke="#AEAEB2" stroke-width="1.5"/>
  <circle cx="294" cy="24" r="3.5" fill="white" stroke="#AEAEB2" stroke-width="1.5"/>
  <circle cx="382" cy="30" r="3.5" fill="white" stroke="#AEAEB2" stroke-width="1.5"/>
  <!-- Current dot: severity colour, solid, larger -->
  <circle cx="470" cy="27" r="7" fill="#F4D00E"/>
  <!-- Past score labels -->
  <text x="30" y="64" text-anchor="middle" font-family="Verdana" font-size="10.5" fill="#AEAEB2">62</text>
  <text x="118" y="64" text-anchor="middle" font-family="Verdana" font-size="10.5" fill="#AEAEB2">71</text>
  <text x="206" y="64" text-anchor="middle" font-family="Verdana" font-size="10.5" fill="#AEAEB2">84</text>
  <text x="294" y="64" text-anchor="middle" font-family="Verdana" font-size="10.5" fill="#AEAEB2">79</text>
  <text x="382" y="64" text-anchor="middle" font-family="Verdana" font-size="10.5" fill="#AEAEB2">73</text>
  <!-- Current score -->
  <text x="470" y="74" text-anchor="middle" font-family="Verdana" font-size="13" font-weight="700" fill="#F4D00E">76</text>
</svg>
</body>
</html>
